@using System.Reflection
@inject HttpClient Http

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">🌙 CoolSleep</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                v@(AppVersion)
            </MudText>
            <MudDivider Class="my-2" />
            <MudText>Par Thierry Verdier</MudText>
            <MudLink Href="https://github.com/DevEatSleep/" Target="_blank">
                github.com/DevEatSleep
            </MudLink>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => MudDialog.Close())">
            Fermer
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private string AppVersion { get; set; } = "1.0.0";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetAsync("/version.json");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                // Simple JSON parsing: extract "version": "X.Y.Z"
                var match = System.Text.RegularExpressions.Regex.Match(json, @"""version"":\s*""([^""]+)""");
                if (match.Success)
                {
                    AppVersion = match.Groups[1].Value;
                }
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"Failed to fetch version.json: {ex.Message}");
        }
    }
}
